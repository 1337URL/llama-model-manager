# Flask Configuration
SECRET_KEY=your-secret-key-here
LLAMA_ARG_MODELS_DIR=./downloads

# API Token for programmatic access (optional)
# Leave empty to require login for /api/download and /api/rules
API_TOKEN=

# Reverse Proxy Configuration
# Upstream URL to proxy requests to
# Leave empty to disable reverse proxy functionality
PROXY_UPSTREAM_URL=

# Enable CORS for proxy requests (default: false)
# Set to 'true' to allow cross-origin requests to the proxy
PROXY_ENABLE_CORS=false

# Proxy timeout in seconds (default: 30)
PROXY_TIMEOUT=30

# Proxy Rules Configuration
# JSON array of rule objects. Each rule has:
# - match: { url (optional), content_type (optional), method (optional) }
# - transform: { type: 'json' or 'text', action, ... }
# Leave empty to disable rule-based transformations
PROXY_RULES='[]'

# Example rule to remove sensitive fields from JSON (create via Rule Builder):
# PROXY_RULES='[{"match": {"url": "https://api.example.com/v1/*", "content_type": "application/json"}, "transform": {"type": "json", "action": "remove", "fields": ["password", "secret_token"]}}]'

# Example rule to add fields to JSON responses (create via Rule Builder):
# PROXY_RULES='[{"match": {"url": "https://api.example.com/*", "content_type": "application/json"}, "transform": {"type": "json", "action": "add", "fields": {"processed_by": "llama-manager"}}}]'

# Example rule to rename JSON keys (create via Rule Builder):
# PROXY_RULES='[{"match": {"url": "https://api.example.com/v1/users", "content_type": "application/json"}, "transform": {"type": "json", "action": "rename", "renames": {"id": "user_id", "name": "username"}}}]'

# Example rule to set default values (create via Rule Builder):
# PROXY_RULES='[{"match": {"content_type": "application/json"}, "transform": {"type": "json", "action": "set", "fields": {"active": true}}}]'

# Example rule for text replacement (create via Rule Builder):
# PROXY_RULES='[{"match": {"content_type": "text/html"}, "transform": {"type": "text", "action": "replace", "search": "www.example.com", "replace": "api.example.com"}}]'

# Example rule for regex replacement (create via Rule Builder):
# PROXY_RULES='[{"match": {"content_type": "text/html"}, "transform": {"type": "text", "action": "regex", "pattern": "href=\"(https?://www\\.example\\.com/)", "replacement": "href=\"https://api.example.com/"}}]'
